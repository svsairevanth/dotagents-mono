{
  "name": "@dotagents/shared",
  "version": "0.0.1",
  "description": "Shared design tokens, types, and utilities for DotAgents apps",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./colors": {
      "types": "./dist/colors.d.ts",
      "import": "./dist/colors.mjs",
      "require": "./dist/colors.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.js"
    },
    "./tts-preprocessing": {
      "types": "./dist/tts-preprocessing.d.ts",
      "import": "./dist/tts-preprocessing.mjs",
      "require": "./dist/tts-preprocessing.js"
    },
    "./chat-utils": {
      "types": "./dist/chat-utils.d.ts",
      "import": "./dist/chat-utils.mjs",
      "require": "./dist/chat-utils.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.mjs",
      "require": "./dist/providers.js"
    },
    "./languages": {
      "types": "./dist/languages.d.ts",
      "import": "./dist/languages.mjs",
      "require": "./dist/languages.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.mjs",
      "require": "./dist/session.js"
    },
    "./shell-parse": {
      "types": "./dist/shell-parse.d.ts",
      "import": "./dist/shell-parse.mjs",
      "require": "./dist/shell-parse.js"
    },
    "./connection-recovery": {
      "types": "./dist/connection-recovery.d.ts",
      "import": "./dist/connection-recovery.mjs",
      "require": "./dist/connection-recovery.js"
    },
    "./api-types": {
      "types": "./dist/api-types.d.ts",
      "import": "./dist/api-types.mjs",
      "require": "./dist/api-types.js"
    },
    "./hub": {
      "types": "./dist/hub.d.ts",
      "import": "./dist/hub.mjs",
      "require": "./dist/hub.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "private": true
}

